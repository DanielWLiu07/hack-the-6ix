# Copy to web/server/.env (gitignored). Never commit the real values.

# MongoDB Atlas connection string (from worker db once the ht6 cluster exists).
# Leave unset to run on the in-memory fallback - everything still works.
# Shape: mongodb+srv://<user>:<password>@ht6.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Database name (optional, default: ht6)
MONGODB_DB=ht6

# the hub's vars (documented here so there's one env file)
PORT=3001
# MJPEG source for the /stream proxy (robot's camera pipeline on :8080)
ROBOT_STREAM_URL=http://localhost:8080/stream

# Base44 "Orchard OS" webhook (docs/BASE44.md). Every pick_event is POSTed here
# as { job_id?, fruit, ripeness, bin, success, ts } with an X-Base44-Secret header.
# Leave BASE44_WEBHOOK_URL unset to disable forwarding entirely (default).
BASE44_WEBHOOK_URL=
BASE44_SECRET=
# Optional HarvestJob id to tag every forwarded PickReport with.
BASE44_JOB_ID=
# Per-request timeout in ms (default 4000).
BASE44_TIMEOUT_MS=4000

# Vercel Blob - public storage for pick photos so they load on the Vercel
# dashboard / judges' phones (not just clients that can reach the laptop hub).
# Unset = pick photos fall back to local files served from the hub at /media.
# Get it: Vercel -> project hack-the-6ix -> Storage -> Blob -> create store
# (or `vercel blob store add ht6-media`), then paste the token here.
BLOB_READ_WRITE_TOKEN=

# Auth0 (hub-side JWT verification). Unset = auth disabled (dev bypass): clients
# are anonymous and picks/commands are unattributed. Set both to verify the
# access token browsers pass on the socket handshake and attribute actions to
# the operator (the Atlas audit trail - see docs/MONGODB_AUTH0.md). We DON'T
# restrict data (hackathon): everyone still sees the same shared dashboard.
# AUTH0_DOMAIN = your tenant, no https:// (e.g. dev-ab12cd.us.auth0.com)
# AUTH0_AUDIENCE = the Auth0 API "Identifier" (e.g. https://ht6-api)
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
# Namespaced custom claim for roles, if you add an Auth0 Action (optional).
AUTH0_ROLES_CLAIM=https://ht6/roles

# Demo panic switch (force-sim) - see docs/DEPLOY.md
# Boot mode: off | on | auto. `auto` self-heals the demo if the real robot dies
# (spawns sim.js as a fallback iff no real robot for PANIC_GRACE_MS). Also
# switchable live: POST /api/force-sim {"mode":"auto"} or {"on":true}.
FORCE_SIM=off
PANIC_GRACE_MS=4000
# If set, POST /api/force-sim requires an X-Panic-Key header (reads stay open).
PANIC_KEY=
# Uncomment only if the lidar sim emits scans separately, so the fallback sim skips lidar:
#SIM_LIDAR=0
