# Copy to web/.env.local (gitignored). Values prefixed VITE_ are intentionally
# public browser configuration; never put an Auth0 client secret in this file.

# Auth0 Single Page Application settings
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=

# Auth0 API Identifier. This must exactly match AUTH0_AUDIENCE in
# web/server/.env so the hub can verify the browser's JWT.
VITE_AUTH0_AUDIENCE=https://ht6-api

# URL of the local telemetry hub (optional; defaults to http://localhost:3001)
VITE_SERVER_URL=http://localhost:3001
