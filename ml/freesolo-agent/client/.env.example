# FarmHand client config.
# Copy this file to `.env` (which is git-ignored) and fill in the values.
# `.env` is loaded automatically by farmhand.py and service.py. Never commit it.
#
#   cp .env.example .env    then edit .env
#
# You only NEED the API key to start. Leave FARMHAND_URL blank until you have
# trained + deployed a model on Freesolo; blank = safe built-in mock mode.

# --- required to talk to Freesolo ---
# Your Freesolo API key (freesolo.co -> API Keys). Also used by the `flash` CLI.
FREESOLO_API_KEY=

# --- fill these in AFTER `flash deploy <run-id>` ---
# OpenAI-compatible base URL of your deployed model. Get it from
# `flash deployments --json` (looks like https://<your-endpoint>/v1).
# BLANK = stay in built-in mock mode (nothing breaks, safe default).
FARMHAND_URL=

# The deployed model / run-id to call (the `flash deploy <run-id>` alias).
FARMHAND_MODEL=

# --- optional tuning (sane defaults) ---
# 1 = ask the server to force JSON output (recommended). 0 = disable.
FARMHAND_JSON_MODE=1
# Request timeout (seconds) and sampling temperature (0 = deterministic).
FARMHAND_TIMEOUT=20
FARMHAND_TEMPERATURE=0
